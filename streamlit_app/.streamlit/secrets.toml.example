# ─────────────────────────────────────────────────────────────
# .streamlit/secrets.toml.example
#
# 1. Copy this file to .streamlit/secrets.toml
# 2. Fill in your real DATABASE_URL
# 3. The password_hash below is for "willow@swift" — regenerate
#    if you change the password:
#
#       python -c "import bcrypt; print(bcrypt.hashpw(b'YOUR_PASSWORD', bcrypt.gensalt(12)).decode())"
#
# 4. Do NOT commit secrets.toml to version control.
# ─────────────────────────────────────────────────────────────

[database]
# Your Neon (or other PostgreSQL) connection string
url = "postgresql://user:password@host/dbname?sslmode=require"

[admin]
username      = "Ojasvi_Khola"
# bcrypt hash of "willow@swift" — replace if you change the password
password_hash = "$2b$12$AN6BYcKUmTcJfarB53cDmObtzpNtlNql6t0U6YSIFCQvIRuyTUo8S"
